/**
 * 16-bit incrementer:
 * out = in + 1
 */
CHIP Inc16 {
    IN in[16];
    OUT out[16];

    PARTS:

    // Use Add16 to add in to 1. Easy peasy... lemon SQUEEZY!
    Add16(a = in, b[0] = true, out = out);
}