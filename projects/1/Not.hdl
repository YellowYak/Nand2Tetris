// and the book "The Elements of Computing Systems"
// by Nisan and Schocken, MIT Press.
/**
 * Not gate:
 * if (in) out = 0, else out = 1
 */
CHIP Not {
    IN in;
    OUT out;

    PARTS:

    // Nand(1, 1) = 0
    // Nand(0, 0) = 1
    // --------------
    // Ergo, Nand(a, a) = Not(a)
    
    Nand(a = in, b = in, out = out);
}
