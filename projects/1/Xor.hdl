/**
 * Exclusive-or gate:
 * if ((a and Not(b)) or (Not(a) and b)) out = 1, else out = 0
 */
CHIP Xor {
    IN a, b;
    OUT out;

    PARTS:
    
    Not(in = b, out = notb);
    And(a = a, b = notb, out = aandNotb);

    Not(in = a, out = nota);
    And(a = nota, b = b, out = notaAndb);

    Or(a = aandNotb, b = notaAndb, out = out);
}